{
  "name": "Minimal Starter",
  "version": "1.0.0",
  "fonts": {
    "heading": "Inter",
    "body": "Inter",
    "mono": "JetBrains Mono"
  },
  "colors": {
    "primary": "#000000",
    "secondary": "#666666",
    "background": "#FFFFFF",
    "text": "#000000"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px"
  },
  "typography": {
    "h1": {
      "size": "48px",
      "lineHeight": "1.2",
      "weight": "700"
    },
    "h2": {
      "size": "36px",
      "lineHeight": "1.3",
      "weight": "700"
    },
    "h3": {
      "size": "24px",
      "lineHeight": "1.4",
      "weight": "600"
    },
    "body": {
      "size": "16px",
      "lineHeight": "1.6",
      "weight": "400"
    },
    "small": {
      "size": "14px",
      "lineHeight": "1.5",
      "weight": "400"
    }
  },
  "rules": [
    "Use design system fonts only",
    "Use design system colors only",
    "Use design system spacing scale only",
    "Maintain WCAG AA contrast ratios (4.5:1 for text)"
  ]
}
